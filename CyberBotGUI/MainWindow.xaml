<Window x:Class="CyberBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberBotGUI"
        mc:Ignorable="d"
        Title="CyberBot" Height="800" Width="900" Background="#1e1e2e">

    <Grid Background="#FF1E1E2E">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- heading -->
        <TextBlock Grid.Row="0"
            FontSize="35"
            HorizontalAlignment="Center"
            Text="CyberBot"
            VerticalAlignment="Center"
            Foreground="#FFCBA6F7"
            FontFamily="JetBrainsMono NFM"
            FontWeight="Bold">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="0" Color="#FF181825" Opacity="1" BlurRadius="6"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- tab control -->
        <TabControl Grid.Row="1" Grid.RowSpan="2"
                    Background="#1e1e2e"
                    BorderBrush="#313244"
                    Foreground="#FFCBA6F7"
                    Margin="5">

            <!-- CHAT TAB -->
            <TabItem Header="Chat" Foreground="#FFCBA6F7" Background="#181825">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="10"
                            Background="#181825"
                            BorderBrush="#313244"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputBox"
                                 KeyDown="InputBox_KeyDown"
                                 Margin="5"
                                 FontSize="16"
                                 Background="#FF181825"
                                 Foreground="#FFCBA6F7"/>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="Send"
                                Click="SendButton_Click"
                                FontSize="25"
                                Margin="5"
                                Background="#FF181825"
                                Foreground="#FFCBA6F7"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TASKS TAB -->
            <TabItem Header="Tasks" Foreground="#FFCBA6F7" Background="#181825">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- input fields -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Title" Foreground="#FFCBA6F7" Margin="0,5"/>
                        <TextBox x:Name="TaskTitleBox"
                                 Background="#181825"
                                 Foreground="#FFCBA6F7"
                                 BorderBrush="#313244"
                                 Margin="0,0,0,5"
                                 FontSize="14"/>

                        <TextBlock Text="Description" Foreground="#FFCBA6F7" Margin="0,5"/>
                        <TextBox x:Name="TaskDescBox"
                                 Background="#181825"
                                 Foreground="#FFCBA6F7"
                                 BorderBrush="#313244"
                                 Margin="0,0,0,5"
                                 FontSize="14"/>

                        <TextBlock Text="Reminder (e.g. Remind me in 7 days)" Foreground="#FFCBA6F7" Margin="0,5"/>
                        <TextBox x:Name="TaskReminderBox"
                                 Background="#181825"
                                 Foreground="#FFCBA6F7"
                                 BorderBrush="#313244"
                                 Margin="0,0,0,5"
                                 FontSize="14"/>

                        <Button x:Name="AddTaskButton"
                                Content="Add Task"
                                Click="AddTaskButton_Click"
                                Background="#181825"
                                Foreground="#A6E3A1"
                                FontSize="14"
                                Margin="0,5"/>
                    </StackPanel>

                    <!-- task list -->
                    <ListBox x:Name="TaskListBox"
                             Grid.Row="1"
                             Background="#181825"
                             Foreground="#FFCBA6F7"
                             BorderBrush="#313244"
                             FontSize="13"/>

                    <!-- action buttons -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="CompleteTaskButton"
                            Content="Mark Complete"
                            Click="CompleteTaskButton_Click"
                            Background="#181825"
                            Foreground="#A6E3A1"
                            FontSize="13"
                            Margin="0,0,10,0"
                            Padding="10,5"/>

                    <Button x:Name="IncompleteTaskButton"
                            Content="Mark Incomplete"
                            Click="IncompleteTaskButton_Click"
                            Background="#181825"
                            Foreground="#FAB387"
                            FontSize="13"
                            Margin="0,0,10,0"
                            Padding="10,5"/>

                    <Button x:Name="DeleteTaskButton"
                            Content="Delete Task"
                            Click="DeleteTaskButton_Click"
                            Background="#181825"
                            Foreground="#F38BA8"
                            FontSize="13"
                            Padding="10,5"/>
                </StackPanel>                   
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>
</Window>
